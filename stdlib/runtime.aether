// `use runtime;` brings every libaether_rt extern in scope. Mirrors the
// real C-ABI surface in `runtime/src/lib.rs` and `runtime/src/cuda.rs`,
// in the form aetherc's asm backend can compile today (i64 handles +
// i32 sizes — the eventual `Tensor<f32, [M, K]>` shape generics in the
// other stdlib/*.aether files are aspirational and need more language
// surface before they round-trip).
//
// Cuts the ~60 lines of extern decl boilerplate at the top of every
// model program down to one line: `use runtime;`.

// ----- host memory + init ---------------------------------------------
extern fn aether_alloc_f32(n: i32) -> i64;
extern fn aether_alloc_i32(n: i32) -> i64;
extern fn aether_free_f32(p: i64, n: i32) -> i32;
extern fn aether_free_i32(p: i64, n: i32) -> i32;
extern fn aether_init_normal_f32(p: i64, n: i32, scale: f32, seed: i64) -> i32;
extern fn aether_init_constant_f32(p: i64, n: i32, value: f32) -> i32;
extern fn aether_print_kv_i64(label: i64, value: i64) -> i32;
extern fn aether_print_kv_f32(label: i64, value: f32) -> i32;
extern fn aether_abs_i64(x: i64) -> i64;
extern fn aether_min_i64(a: i64, b: i64) -> i64;
extern fn aether_max_i64(a: i64, b: i64) -> i64;
extern fn aether_min_f32(a: f32, b: f32) -> f32;
extern fn aether_max_f32(a: f32, b: f32) -> f32;
