extern fn aether_bf16_to_f32(b: i32) -> f32;
extern fn aether_f32_to_f16(x: f32) -> i32;
extern fn aether_f16_to_f32(h: i32) -> f32;
extern fn aether_op_matmul_bf16_f32_out(a: i64, b: i64, out: i64, m: i32, k: i32, n: i32) -> i32;
extern fn aether_pack_f32_to_bf16(src: i64, dst: i64, n: i32) -> i32;
// Self-host bootstrap I/O + memory primitives (roadmap #27).
extern fn aether_read_file(path: i64) -> i64;
