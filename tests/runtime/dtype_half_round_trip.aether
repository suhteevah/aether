// roadmap: P7.1, P17.1
// expect: exit=0
//
// Half-precision dtype round-trip witness. Verifies:
//   bf16: f32 → bf16 → f32 within 2^-7 relative error (8-bit mantissa)
//   f16:  f32 → f16  → f32 within 2^-10 relative error (10-bit mantissa)
//
// Sample values exercise normal range; subnormal/inf paths are present
// in the impl but not asserted here (covered by Rust unit tests).
use runtime;

fn check_bf16(x: f32) -> i32 {
    let r: f32 = aether_bf16_to_f32(aether_f32_to_bf16(x));
    let rel: f32 = aether_abs_f32(r - x) / aether_abs_f32(x);
    if rel > 0.01 { 1 } else { 0 }
}

fn check_f16(x: f32) -> i32 {
    let r: f32 = aether_f16_to_f32(aether_f32_to_f16(x));
    let rel: f32 = aether_abs_f32(r - x) / aether_abs_f32(x);
    if rel > 0.001 { 1 } else { 0 }
}

fn main() -> i32 {
    // bf16 round-trip
    if check_bf16(1.0)        != 0 { return 1; }
    if check_bf16(3.14159)    != 0 { return 2; }
    if check_bf16(0.5)        != 0 { return 3; }
    if check_bf16(100.0)      != 0 { return 4; }
    if check_bf16(0.001)      != 0 { return 5; }

    // f16 round-trip
    if check_f16(1.0)         != 0 { return 6; }
    if check_f16(3.14159)     != 0 { return 7; }
    if check_f16(0.5)         != 0 { return 8; }
    if check_f16(100.0)       != 0 { return 9; }
    if check_f16(0.001)       != 0 { return 10; }

    // Bit-exact zero round-trip.
    if aether_bf16_to_f32(aether_f32_to_bf16(0.0)) != 0.0 { return 11; }
    if aether_f16_to_f32(aether_f32_to_f16(0.0))   != 0.0 { return 12; }

    0
}
