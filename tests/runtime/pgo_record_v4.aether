// roadmap: P15.5
// expect: exit=42
//
// FR-15.5 — Profile-guided optimisation surface. The runtime ships
// `aether_pgo_record_branch(site_id, taken)` + `_record_call(site)` +
// `_branch_freq(site)` + `_call_count(site)` + `_reset()` + `_dump()`.
// A real driver would feed these counts into the asm backend's branch
// layout decisions; the witness exercises the FFI and confirms the
// recorded counts match.
extern fn aether_pgo_reset() -> i32;
extern fn aether_pgo_record_branch(site_id: i64, taken: i64) -> i32;
extern fn aether_pgo_record_call(callsite_id: i64) -> i32;
extern fn aether_pgo_branch_freq(site_id: i64) -> f32;
extern fn aether_pgo_call_count(callsite_id: i64) -> i64;

fn main() -> i32 {
    aether_pgo_reset();

    // Site 1: 3-of-4 taken.
    aether_pgo_record_branch(1, 1);
    aether_pgo_record_branch(1, 1);
    aether_pgo_record_branch(1, 0);
    aether_pgo_record_branch(1, 1);

    aether_pgo_record_call(7);
    aether_pgo_record_call(7);
    aether_pgo_record_call(7);

    let cnt: i64 = aether_pgo_call_count(7);   // 3
    if cnt != 3 { return 1; }

    let f: f32 = aether_pgo_branch_freq(1);    // 0.75
    if f < 0.74 { return 2; }
    if f > 0.76 { return 3; }

    aether_pgo_reset();
    if aether_pgo_call_count(7) != 0 { return 4; }
    42
}
