// roadmap: P6.4
// expect: exit=42
//
// Statement-vs-expression boundary: a block-like statement (if/while/for/loop/
// match) in statement position is a COMPLETE statement — a following
// parenthesized expression is a NEW statement (or the tail), NOT a postfix call
// on the block. Regression: `for {...} (s*7) as i32` used to parse as
// `Call { callee: <for-expr>, args: [s*7] }` -> "non-ident callee".
fn main() -> i32 {
    let mut s: i64 = 0;
    for k in 0..6 { s = s + 1; }      // s = 6
    (s * 7) as i32                    // a NEW expression (the tail) -> 42
}
