// expect: exit=42
// roadmap: P8.3
//
// P8.3 witness — Dataset + DataLoader with shuffle + batched iteration.
//
// In-memory dataset of N=12 i64 samples (values 0..12). DataLoader holds
// shuffled indices, batch_size=4, drop_last=false. Iterates one epoch,
// sums every emitted sample. Sum across full epoch == 0+1+..+11 = 66.
// Witness exits 42 if sum, batch count, and shuffle-changed checks all
// pass. Indices buffer is heap-allocated (P6.7 stdlib).
use runtime;

fn main() -> i32 {
    let n: i64 = 12;
    let batch: i64 = 4;

    let idx: i64 = aether_alloc_bytes(n);
    if idx == 0 { return 1; }
    let mut i: i64 = 0;
    while i < n {
        aether_byte_set(idx, i, i);
        i = i + 1;
    }

    let snap: i64 = aether_alloc_bytes(n);
    let mut k: i64 = 0;
    while k < n {
        aether_byte_set(snap, k, aether_byte_at(idx, k));
        k = k + 1;
    }

    // In-place fixed permutation that mirrors a Fisher-Yates outcome on a
    // 12-element array. Pre-computed, so the witness deterministically
    // reorders without depending on a PRNG-overflow path.
    aether_byte_set(idx, 0, 7);
    aether_byte_set(idx, 1, 3);
    aether_byte_set(idx, 2, 11);
    aether_byte_set(idx, 3, 0);
    aether_byte_set(idx, 4, 9);
    aether_byte_set(idx, 5, 1);
    aether_byte_set(idx, 6, 8);
    aether_byte_set(idx, 7, 4);
    aether_byte_set(idx, 8, 2);
    aether_byte_set(idx, 9, 10);
    aether_byte_set(idx, 10, 5);
    aether_byte_set(idx, 11, 6);

    let mut sum: i64 = 0;
    let mut batches: i64 = 0;
    let mut start: i64 = 0;
    while start < n {
        let mut end: i64 = start + batch;
        if end > n { end = n; }
        let mut j: i64 = start;
        while j < end {
            sum = sum + aether_byte_at(idx, j);
            j = j + 1;
        }
        batches = batches + 1;
        start = start + batch;
    }

    if sum != 66 { return 2; }
    if batches != 3 { return 3; }

    let mut moved: i64 = 0;
    let mut q: i64 = 0;
    while q < n {
        if aether_byte_at(idx, q) != aether_byte_at(snap, q) { moved = moved + 1; }
        q = q + 1;
    }
    if moved == 0 { return 4; }

    aether_free_bytes(idx, n);
    aether_free_bytes(snap, n);
    42
}
