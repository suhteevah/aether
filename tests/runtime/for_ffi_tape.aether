// expect: exit=7
// for-loop + FFI: drive the runtime tape from inside an Aether for loop.
extern fn aether_autodiff_init(tape: i64) -> i32;
extern fn aether_autodiff_push(tape: i64, value: i64) -> i32;
extern fn aether_rt_self_check() -> i32;

fn main() -> i32 {
    aether_autodiff_init(0);
    for i in 0..7 {
        aether_autodiff_push(0, 0);
    }
    aether_rt_self_check()
}
