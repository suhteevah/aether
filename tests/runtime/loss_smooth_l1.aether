// roadmap: P7.6
// expect: exit=0
// Smooth-L1 (beta=1.0). Diffs span both regimes (|d|<beta and |d|>beta).
use runtime;

fn main() -> i32 {
    let n: i32 = 4;
    let pred:   i64 = aether_alloc_f32(n);
    let target: i64 = aether_alloc_f32(n);
    let dpred:  i64 = aether_alloc_f32(n);
    if pred == 0 { return 1; }
    let beta: f32 = 1.0;

    aether_store_f32(pred, 0, 1.25);
    aether_store_f32(pred, 1, 3.0);
    aether_store_f32(pred, 2, 0.5);
    aether_store_f32(pred, 3, 4.0);

    aether_store_f32(target, 0, 1.0);
    aether_store_f32(target, 1, 0.0);
    aether_store_f32(target, 2, 1.0);
    aether_store_f32(target, 3, 1.5);

    aether_op_smooth_l1_backward_f32(pred, target, dpred, n, beta);

    let eps: f32 = 0.001;
    let tol: f32 = 0.005;
    let mut i: i32 = 0;
    while i < n {
        let saved: f32 = aether_load_f32(pred, i);
        aether_store_f32(pred, i, saved + eps);
        let lp: f32 = aether_op_smooth_l1_f32(pred, target, n, beta);
        aether_store_f32(pred, i, saved - eps);
        let lm: f32 = aether_op_smooth_l1_f32(pred, target, n, beta);
        aether_store_f32(pred, i, saved);
        let num: f32 = (lp - lm) / (2.0 * eps);
        let ana: f32 = aether_load_f32(dpred, i);
        if aether_abs_f32(num - ana) > tol { return 2 + i; }
        i = i + 1;
    }
    0
}
