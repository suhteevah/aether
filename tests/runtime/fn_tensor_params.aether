// expect: exit=0
// requires: cuda
//
// Free function takes Tensor params and dispatches a method call inside.
// The body can use `x.matmul(...)` because the param's compile-time
// shape is propagated into the per-fn `tensor_shapes` sidecar at the
// param-spill stage. The whole training step extracted into a reusable
// fn — closer to how a real `forward` body in PyTorch reads.
use runtime;

const BSZ: i32 = 8;
const KK:  i32 = 16;
const NN:  i32 = 4;

fn matmul_into(
    x: Tensor<f32, [BSZ, KK]>,
    w: Tensor<f32, [KK, NN]>,
    y: Tensor<f32, [BSZ, NN]>,
) -> i32 {
    x.matmul(&w, &mut y);
    0
}

fn main() -> i32 {
    aether_dev_init();

    let h_x: i64 = aether_alloc_f32(128);
    let h_w: i64 = aether_alloc_f32(64);
    aether_init_normal_f32(h_x, 128, 1.0, 1);
    aether_init_normal_f32(h_w, 64, 0.1, 7);

    let x: Tensor<f32, [BSZ, KK]>;
    let w: Tensor<f32, [KK, NN]>;
    let y: Tensor<f32, [BSZ, NN]>;
    aether_dev_h2d_f32(h_x, x, 128);
    aether_dev_h2d_f32(h_w, w, 64);

    matmul_into(x, w, y);
    aether_dev_sync();

    aether_free_f32(h_x, 128);
    aether_free_f32(h_w, 64);
    0
}
