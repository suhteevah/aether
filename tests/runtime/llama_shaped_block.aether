// roadmap: P17.19
// expect: exit=42
//
// FR-17.19 PARTIAL witness — Llama-shaped 1-block transformer forward
// pass on CPU through real runtime ops.
//
// EXPLICIT SCOPE:
//   - Single transformer block (embedding → LN → attention → residual)
//   - Forward only (no training, no autodiff)
//   - Hardcoded weights (no SafeTensors / GGUF load)
//   - LayerNorm in place of RMSNorm (architecture shape preserved)
//   - Dimensions: vocab=8, d=4, seq=4 (NOT 1B parameters)
//   - No HF reference numerics check (audit-honest cap)
//
// What this PROVES:
//   - The runtime + asm chain can wire an embedding lookup + LayerNorm
//     + Q/K/V projections + SDPA + Wo + residual end-to-end on CPU.
//   - All matmul shapes line up; all sizes agree at the ABI boundary.
//
// What it does NOT prove (still gating v4 SHIP):
//   - Llama-1B weight load from SafeTensors.
//   - HF Transformers reference parity within 1e-3.
//   - Multi-block stack + MLP + tied LM head.
//   - Training to coherent generation.
//
// Exit 42 iff the final residual output has a finite, non-zero sum
// in the expected range. Exit codes 1-9 localise alloc / op-call /
// finite-check failures.
use runtime;

extern fn aether_alloc_i32(n: i32) -> i64;
extern fn aether_free_i32(p: i64, n: i32) -> i32;
extern fn aether_store_i32(p: i64, i: i32, v: i32);
extern fn aether_sum_f32(p: i64, n: i32) -> f32;

extern fn aether_op_embedding_lookup_f32(
    w: i64, ids: i64, out: i64, b: i32, s_len: i32, v_size: i32, d: i32,
) -> i32;
extern fn aether_op_matmul_f32(a: i64, b: i64, c: i64, m: i32, k: i32, n: i32) -> i32;
extern fn aether_op_layer_norm_f32(
    x: i64, gamma: i64, beta: i64, eps: f32,
    out: i64, mean_out: i64, inv_std_out: i64, rows: i32, d: i32,
) -> i32;
extern fn aether_op_sdpa_causal_f32(
    q: i64, k: i64, v: i64, out: i64, attn_out: i64,
    bh: i32, s_len: i32, d: i32,
) -> i32;
extern fn aether_op_add_inplace_f32(x: i64, y: i64, n: i32) -> i32;

fn fill_pattern(p: i64, n: i32, base: f32, step: f32) {
    let mut i: i32 = 0;
    while i < n {
        let v: f32 = base + f32(i) * step;
        aether_store_f32(p, i, v);
        i = i + 1;
    }
}

fn fill_const(p: i64, n: i32, c: f32) {
    let mut i: i32 = 0;
    while i < n {
        aether_store_f32(p, i, c);
        i = i + 1;
    }
}

fn main() -> i32 {
    let v_size: i32 = 8;
    let d: i32 = 4;
    let s_len: i32 = 4;

    let embed_w: i64 = aether_alloc_f32(32);   // v_size * d = 32
    let ids: i64 = aether_alloc_i32(s_len);
    let x: i64 = aether_alloc_f32(16);         // s_len * d = 16
    let ln_g: i64 = aether_alloc_f32(d);
    let ln_b: i64 = aether_alloc_f32(d);
    let ln_out: i64 = aether_alloc_f32(16);
    let ln_mean: i64 = aether_alloc_f32(s_len);
    let ln_inv: i64 = aether_alloc_f32(s_len);
    if embed_w == 0 { return 1; }
    if ids == 0 { return 2; }
    if x == 0 { return 3; }

    let wq: i64 = aether_alloc_f32(16);        // d * d
    let wk: i64 = aether_alloc_f32(16);
    let wv: i64 = aether_alloc_f32(16);
    let wo: i64 = aether_alloc_f32(16);
    let q: i64 = aether_alloc_f32(16);
    let k: i64 = aether_alloc_f32(16);
    let v_buf: i64 = aether_alloc_f32(16);
    let attn_out: i64 = aether_alloc_f32(16);
    let attn_scratch: i64 = aether_alloc_f32(16);
    let proj_out: i64 = aether_alloc_f32(16);

    // Fill weights with deterministic patterns.
    fill_pattern(embed_w, 32, 0.1, 0.03);
    fill_const(ln_g, d, 1.0);
    fill_const(ln_b, d, 0.0);
    fill_pattern(wq, 16, 0.05, 0.02);
    fill_pattern(wk, 16, 0.05, 0.02);
    fill_pattern(wv, 16, 0.05, 0.02);
    fill_pattern(wo, 16, 0.05, 0.02);

    // Token ids: 0, 1, 2, 3.
    aether_store_i32(ids, 0, 0);
    aether_store_i32(ids, 1, 1);
    aether_store_i32(ids, 2, 2);
    aether_store_i32(ids, 3, 3);

    // 1. Embedding lookup.
    let rc1: i32 = aether_op_embedding_lookup_f32(embed_w, ids, x, 1, s_len, v_size, d);
    if rc1 != 0 { return 4; }

    // 2. LayerNorm(x).
    let rc2: i32 = aether_op_layer_norm_f32(x, ln_g, ln_b, 0.00001,
                                             ln_out, ln_mean, ln_inv, s_len, d);
    if rc2 != 0 { return 5; }

    // 3. Q/K/V projections.
    let rc3: i32 = aether_op_matmul_f32(ln_out, wq, q, s_len, d, d);
    if rc3 != 0 { return 6; }
    let rc4: i32 = aether_op_matmul_f32(ln_out, wk, k, s_len, d, d);
    if rc4 != 0 { return 6; }
    let rc5: i32 = aether_op_matmul_f32(ln_out, wv, v_buf, s_len, d, d);
    if rc5 != 0 { return 6; }

    // 4. Causal SDPA.
    let rc6: i32 = aether_op_sdpa_causal_f32(q, k, v_buf, attn_out, attn_scratch,
                                              1, s_len, d);
    if rc6 != 0 { return 7; }

    // 5. Output projection.
    let rc7: i32 = aether_op_matmul_f32(attn_out, wo, proj_out, s_len, d, d);
    if rc7 != 0 { return 8; }

    // 6. Residual add: x += proj_out.
    let rc8: i32 = aether_op_add_inplace_f32(x, proj_out, 16);
    if rc8 != 0 { return 9; }

    // 7. Sanity-check the output sum.
    let total: f32 = aether_sum_f32(x, 16);

    aether_free_f32(embed_w, 32);
    aether_free_i32(ids, s_len);
    aether_free_f32(x, 16);
    aether_free_f32(ln_g, d);
    aether_free_f32(ln_b, d);
    aether_free_f32(ln_out, 16);
    aether_free_f32(ln_mean, s_len);
    aether_free_f32(ln_inv, s_len);
    aether_free_f32(wq, 16);
    aether_free_f32(wk, 16);
    aether_free_f32(wv, 16);
    aether_free_f32(wo, 16);
    aether_free_f32(q, 16);
    aether_free_f32(k, 16);
    aether_free_f32(v_buf, 16);
    aether_free_f32(attn_out, 16);
    aether_free_f32(attn_scratch, 16);
    aether_free_f32(proj_out, 16);

    // The architecture is correctly wired iff `total` is a finite
    // non-zero f32. Embeddings start in [0.1, 1.0); after LN + attn +
    // residual the sum should land in a reasonable band — we accept
    // anything in (1.0, 50.0) as evidence the forward pass executed.
    if total < 1.0 { return 10; }
    if total > 50.0 { return 11; }
    42
}
