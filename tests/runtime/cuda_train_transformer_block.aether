// roadmap: P7.3, P8.4
// expect: exit=0
// requires: cuda
//
// FULL transformer block trains end-to-end on GPU through .aether source.
// Architecture (pre-norm-on-MLP, post-attention-residual):
//
//   x_after_attn = x + Wo @ (softmax(Q @ K^T / sqrt(D)) @ V)        (residual 1)
//   x_norm       = LN(x_after_attn; gamma, beta)
//   block_out    = x_after_attn + w2 @ gelu(w1 @ x_norm)             (residual 2)
//   logits       = w_head @ block_out
//   loss         = cross_entropy(logits, labels)
//
// Backward closes through every kernel: matmul_backward_lhs/rhs, gelu_bwd,
// layer_norm_bwd_dx + layer_norm_bwd_params, softmax_backward, matmul_tn,
// matmul_nt â€” and gradient SUMS into shared tensors via aether_op_add_f32_cuda.
//
// 9 learnable weights (Wq, Wk, Wv, Wo, gamma, beta, w1, w2, w_head); each
// updated by AdamW. Exit 0 iff final loss < initial loss.
use runtime;

const SS: i32 = 8;
const DD: i32 = 16;
const HH: i32 = 32;
const NN: i32 = 4;
const DSQ: i32 = 256;
const DH:  i32 = 512;
const HD:  i32 = 512;
const DON: i32 = 64;

fn main() -> i32 {
    aether_dev_init();

    // === Host weights init ===
    let h_x:    i64 = aether_alloc_f32(128);
    let h_wq:   i64 = aether_alloc_f32(256);
    let h_wk:   i64 = aether_alloc_f32(256);
    let h_wv:   i64 = aether_alloc_f32(256);
    let h_wo:   i64 = aether_alloc_f32(256);   // [DD, DD]
    let h_g:    i64 = aether_alloc_f32(16);
    let h_b:    i64 = aether_alloc_f32(16);
    let h_w1:   i64 = aether_alloc_f32(512);   // [DD, HH]
    let h_w2:   i64 = aether_alloc_f32(512);   // [HH, DD]
    let h_whd:  i64 = aether_alloc_f32(64);    // [DD, NN]
    let h_lab:  i64 = aether_alloc_i32(8);
    aether_init_normal_f32(h_x,  128, 1.0, 1);
    aether_init_normal_f32(h_wq, 256, 0.1, 7);
    aether_init_normal_f32(h_wk, 256, 0.1, 11);
    aether_init_normal_f32(h_wv, 256, 0.1, 13);
    aether_init_normal_f32(h_wo, 256, 0.1, 17);
    aether_init_constant_f32(h_g, 16, 1.0);
    aether_init_constant_f32(h_b, 16, 0.0);
    aether_init_normal_f32(h_w1, 512, 0.1, 19);
    aether_init_normal_f32(h_w2, 512, 0.1, 23);
    aether_init_normal_f32(h_whd, 64, 0.1, 29);
    aether_fill_labels_i32(h_lab, 8, 4, 31);

    // === Device tensors ===
    let x:        Tensor<f32, [SS, DD]>;
    let wq:       Tensor<f32, [DD, DD]>;
    let wk:       Tensor<f32, [DD, DD]>;
    let wv:       Tensor<f32, [DD, DD]>;
    let wo:       Tensor<f32, [DD, DD]>;
    let gamma:    Tensor<f32, [DD]>;
    let beta:     Tensor<f32, [DD]>;
    let w1:       Tensor<f32, [DD, HH]>;
    let w2:       Tensor<f32, [HH, DD]>;
    let whd:      Tensor<f32, [DD, NN]>;
    // forward intermediates
    let q:        Tensor<f32, [SS, DD]>;
    let k:        Tensor<f32, [SS, DD]>;
    let v:        Tensor<f32, [SS, DD]>;
    let scores:   Tensor<f32, [SS, SS]>;
    let attn:     Tensor<f32, [SS, SS]>;
    let ctx_buf:  Tensor<f32, [SS, DD]>;
    let attn_out: Tensor<f32, [SS, DD]>;
    let x_aa:     Tensor<f32, [SS, DD]>;       // x_after_attn (residual 1 output)
    let ln_mean:  Tensor<f32, [SS]>;
    let ln_rstd:  Tensor<f32, [SS]>;
    let x_norm:   Tensor<f32, [SS, DD]>;
    let h_pre:    Tensor<f32, [SS, HH]>;
    let h_act:    Tensor<f32, [SS, HH]>;
    let proj:     Tensor<f32, [SS, DD]>;
    let block_out:Tensor<f32, [SS, DD]>;
    let logits:   Tensor<f32, [SS, NN]>;
    let probs:    Tensor<f32, [SS, NN]>;
    // backward intermediates
    let dlogits:  Tensor<f32, [SS, NN]>;
    let dwhd:     Tensor<f32, [DD, NN]>;
    let dblock:   Tensor<f32, [SS, DD]>;
    let dh_act:   Tensor<f32, [SS, HH]>;
    let dh_pre:   Tensor<f32, [SS, HH]>;
    let dw1:      Tensor<f32, [DD, HH]>;
    let dw2:      Tensor<f32, [HH, DD]>;
    let dx_norm:  Tensor<f32, [SS, DD]>;
    let dx_aa_ln: Tensor<f32, [SS, DD]>;
    let dgamma:   Tensor<f32, [DD]>;
    let dbeta:    Tensor<f32, [DD]>;
    let dx_aa:    Tensor<f32, [SS, DD]>;       // dblock + dx_aa_ln
    let dctx:     Tensor<f32, [SS, DD]>;
    let dwo:      Tensor<f32, [DD, DD]>;
    let dattn:    Tensor<f32, [SS, SS]>;
    let dv:       Tensor<f32, [SS, DD]>;
    let dscores:  Tensor<f32, [SS, SS]>;
    let dq:       Tensor<f32, [SS, DD]>;
    let dk:       Tensor<f32, [SS, DD]>;
    let dwq:      Tensor<f32, [DD, DD]>;
    let dwk:      Tensor<f32, [DD, DD]>;
    let dwv:      Tensor<f32, [DD, DD]>;
    // (dx through Wq/Wk/Wv unused â€” x is input â€” so we don't materialise)
    // adamw state
    let m_wq: Tensor<f32, [DSQ]>; let v_wq: Tensor<f32, [DSQ]>;
    let m_wk: Tensor<f32, [DSQ]>; let v_wk: Tensor<f32, [DSQ]>;
    let m_wv: Tensor<f32, [DSQ]>; let v_wv: Tensor<f32, [DSQ]>;
    let m_wo: Tensor<f32, [DSQ]>; let v_wo: Tensor<f32, [DSQ]>;
    let m_g:  Tensor<f32, [DD]>;  let v_g:  Tensor<f32, [DD]>;
    let m_b:  Tensor<f32, [DD]>;  let v_b:  Tensor<f32, [DD]>;
    let m_w1: Tensor<f32, [DH]>;  let v_w1: Tensor<f32, [DH]>;
    let m_w2: Tensor<f32, [HD]>;  let v_w2: Tensor<f32, [HD]>;
    let m_whd:Tensor<f32, [DON]>; let v_whd:Tensor<f32, [DON]>;
    let labels: Tensor<i32, [SS]>;

    aether_dev_h2d_f32(h_x,   x,   128);
    aether_dev_h2d_f32(h_wq,  wq,  256);
    aether_dev_h2d_f32(h_wk,  wk,  256);
    aether_dev_h2d_f32(h_wv,  wv,  256);
    aether_dev_h2d_f32(h_wo,  wo,  256);
    aether_dev_h2d_f32(h_g,   gamma, 16);
    aether_dev_h2d_f32(h_b,   beta,  16);
    aether_dev_h2d_f32(h_w1,  w1, 512);
    aether_dev_h2d_f32(h_w2,  w2, 512);
    aether_dev_h2d_f32(h_whd, whd, 64);
    aether_dev_h2d_i32(h_lab, labels, 8);

    let mut step: i64 = 1;
    let mut initial_loss: f32 = 0.0;
    let mut final_loss: f32 = 0.0;
    while step <= 60 {
        // === Forward ===
        x.matmul(&wq, &mut q);
        x.matmul(&wk, &mut k);
        x.matmul(&wv, &mut v);
        q.matmul_t(&k, &mut scores);
        scores.scale(0.25);
        scores.softmax(&mut attn);
        attn.matmul(&v, &mut ctx_buf);
        ctx_buf.matmul(&wo, &mut attn_out);
        x.add(&attn_out, &mut x_aa);                                 // residual 1
        x_aa.layer_norm(&gamma, &beta, &mut x_norm, &mut ln_mean, &mut ln_rstd, 0.00001);
        x_norm.matmul(&w1, &mut h_pre);
        h_pre.gelu(&mut h_act);
        h_act.matmul(&w2, &mut proj);
        x_aa.add(&proj, &mut block_out);                             // residual 2
        block_out.matmul(&whd, &mut logits);
        let loss: f32 = logits.cross_entropy(&labels, &mut probs);
        if step == 1 { initial_loss = loss; }
        final_loss = loss;
        // === Backward ===
        probs.cross_entropy_backward(&labels, &mut dlogits);
        block_out.matmul_backward_rhs(&dlogits, &mut dwhd);
        dlogits.matmul_backward_lhs(&whd, &mut dblock);
        // dblock splits: residual2 path â†’ dx_aa contribution; proj path â†’ MLP backward.
        h_act.matmul_backward_rhs(&dblock, &mut dw2);
        dblock.matmul_backward_lhs(&w2, &mut dh_act);
        h_pre.gelu_backward(&dh_act, &mut dh_pre);
        x_norm.matmul_backward_rhs(&dh_pre, &mut dw1);
        dh_pre.matmul_backward_lhs(&w1, &mut dx_norm);
        // LN backward (params + dx).
        x_aa.layer_norm_backward_params(&ln_mean, &ln_rstd, &dx_norm, &mut dgamma, &mut dbeta);
        x_aa.layer_norm_backward_dx(&gamma, &ln_mean, &ln_rstd, &dx_norm, &mut dx_aa_ln);
        // dx_aa = dx_aa_ln + dblock (residual 2).
        dx_aa_ln.add(&dblock, &mut dx_aa);
        // Attention output proj.
        ctx_buf.matmul_backward_rhs(&dx_aa, &mut dwo);
        dx_aa.matmul_backward_lhs(&wo, &mut dctx);
        dctx.matmul_t(&v, &mut dattn);
        attn.matmul_tn(&dctx, &mut dv);
        attn.softmax_backward(&dattn, &mut dscores);
        dscores.scale(0.25);
        dscores.matmul(&k, &mut dq);
        dscores.matmul_tn(&q, &mut dk);
        x.matmul_backward_rhs(&dq, &mut dwq);
        x.matmul_backward_rhs(&dk, &mut dwk);
        x.matmul_backward_rhs(&dv, &mut dwv);
        // (dx through attention + residual 1 unused â€” x is the network input)
        // === Optim ===
        wq.adamw_step(&dwq, &mut m_wq, &mut v_wq, 0.05, 0.9, 0.999, 0.00000001, 0.0, step);
        wk.adamw_step(&dwk, &mut m_wk, &mut v_wk, 0.05, 0.9, 0.999, 0.00000001, 0.0, step);
        wv.adamw_step(&dwv, &mut m_wv, &mut v_wv, 0.05, 0.9, 0.999, 0.00000001, 0.0, step);
        wo.adamw_step(&dwo, &mut m_wo, &mut v_wo, 0.05, 0.9, 0.999, 0.00000001, 0.0, step);
        gamma.adamw_step(&dgamma, &mut m_g, &mut v_g, 0.01, 0.9, 0.999, 0.00000001, 0.0, step);
        beta.adamw_step(&dbeta,   &mut m_b, &mut v_b, 0.01, 0.9, 0.999, 0.00000001, 0.0, step);
        w1.adamw_step(&dw1, &mut m_w1, &mut v_w1, 0.05, 0.9, 0.999, 0.00000001, 0.0, step);
        w2.adamw_step(&dw2, &mut m_w2, &mut v_w2, 0.05, 0.9, 0.999, 0.00000001, 0.0, step);
        whd.adamw_step(&dwhd, &mut m_whd, &mut v_whd, 0.05, 0.9, 0.999, 0.00000001, 0.0, step);
        step = step + 1;
    }
    aether_dev_sync();

    aether_free_f32(h_x, 128);
    aether_free_f32(h_wq, 256);
    aether_free_f32(h_wk, 256);
    aether_free_f32(h_wv, 256);
    aether_free_f32(h_wo, 256);
    aether_free_f32(h_g, 16);
    aether_free_f32(h_b, 16);
    aether_free_f32(h_w1, 512);
    aether_free_f32(h_w2, 512);
    aether_free_f32(h_whd, 64);
    aether_free_i32(h_lab, 8);

    if final_loss < initial_loss { 0 } else { 1 }
}
