// expect: exit=42
// roadmap: P10.4
// Witness for asm-level peephole optimizer (instruction selection subset).
// The peephole pass collapses two patterns introduced by the naive code
// generator:
//   1. `movq $imm, %rax / movq %rax, -N(%rbp)` -> `movq $imm, -N(%rbp)`
//   2. `movq %rax, -N(%rbp) / movq -N(%rbp), %rax` -> drop the redundant reload
// This program is dense in both patterns: many `let x = const` bindings and
// many `x = const2` reassignments (each one is a load-store round trip), then
// one tail expression that pulls them all back from stack slots.
fn main() -> i32 {
    let mut a = 1;
    let mut b = 2;
    let mut c = 3;
    let mut d = 4;
    let mut e = 5;
    a = 10;
    b = 11;
    c = 12;
    d = 13;
    e = 14;
    a = 20;
    b = 22;
    c = 24;
    let s1 = a + b;       // 42
    let s2 = c + d;       // 37
    let s3 = e + s1;      // 56
    let _t = s1 - s2 + s3 - 51; // 42 - 37 + 56 - 51 = 10  (kept to exercise reload elim)
    s1                    // 42
}
