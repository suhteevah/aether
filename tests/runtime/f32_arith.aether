// expect: exit=42
// Mul + Sub + Div on f32, then a compare picks the exit code.
//   ((10.0 * 4.5) - 3.0) / 1.0 = 42.0
//   42.0 > 41.5 → true → return 42
fn main() -> i32 {
    let a: f32 = 10.0;
    let b: f32 = 4.5;
    let prod: f32 = a * b;
    let diff: f32 = prod - 3.0;
    let q: f32 = diff / 1.0;
    if q > 41.5 { 42 } else { 0 }
}
