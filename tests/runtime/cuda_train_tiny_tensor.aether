// expect: exit=0
// requires: cuda
//
// Same end-to-end GPU training as `cuda_train_tiny.aether`, but the
// tensor allocs / frees are auto-generated by the language. Compare the
// tops of the two files: the manual version has 9 separate
// `aether_dev_alloc_*` + 9 `aether_dev_free_*` calls; this version
// has zero — the `Tensor<f32, [N]>` declaration auto-emits the alloc,
// the fn epilogue auto-emits the matching free, and `%rax` is preserved
// across the free sequence so the return value survives.
//
// Same model, same hyperparameters, same seed. Exits 0 iff loss
// decreased over 50 steps.
use runtime;

fn main() -> i32 {
    aether_dev_init();
    let bsz: i32 = 8;
    let kk: i32 = 16;
    let nn: i32 = 4;
    let bk: i32 = bsz * kk;       // 128
    let kn: i32 = kk * nn;        // 64
    let bn: i32 = bsz * nn;       // 32

    // Host-side init buffers — still manual for now (host alloc is rarer
    // in real training; the device tensors below are the common case).
    let h_x: i64 = aether_alloc_f32(128);
    let h_w: i64 = aether_alloc_f32(64);
    let h_lab: i64 = aether_alloc_i32(8);
    aether_init_normal_f32(h_x, bk, 1.0, 1);
    aether_init_normal_f32(h_w, kn, 0.1, 7);
    aether_fill_labels_i32(h_lab, bsz, nn, 13);

    // Device tensors — auto-allocated here, auto-freed at fn end.
    let x:    Tensor<f32, [128]>;
    let w:    Tensor<f32, [64]>;
    let y:    Tensor<f32, [32]>;
    let probs:Tensor<f32, [32]>;
    let dy:   Tensor<f32, [32]>;
    let dw:   Tensor<f32, [64]>;
    let mom1: Tensor<f32, [64]>;
    let mom2: Tensor<f32, [64]>;
    let labels: Tensor<i32, [8]>;

    aether_dev_h2d_f32(h_x, x, bk);
    aether_dev_h2d_f32(h_w, w, kn);
    aether_dev_h2d_i32(h_lab, labels, bsz);

    let mut initial: f32 = 0.0;
    let mut final_loss: f32 = 0.0;
    let mut s: i64 = 1;
    while s <= 50 {
        aether_op_matmul_f32_cuda(x, w, y, bsz, kk, nn);
        let loss: f32 = aether_op_cross_entropy_f32_cuda(y, labels, probs, bsz, nn);
        if s == 1 { initial = loss; }
        final_loss = loss;
        aether_op_cross_entropy_backward_f32_cuda(probs, labels, dy, bsz, nn);
        aether_op_matmul_backward_rhs_f32_cuda(x, dy, dw, bsz, kk, nn);
        aether_op_adamw_step_f32_cuda(w, dw, mom1, mom2, 0.05, 0.9, 0.999, 0.00000001, 0.0, s, kn);
        s = s + 1;
    }
    aether_dev_sync();

    aether_free_f32(h_x, 128);
    aether_free_f32(h_w, 64);
    aether_free_i32(h_lab, 8);
    // Tensors auto-freed by the epilogue.

    if final_loss < initial { 0 } else { 1 }
}
