// expect: exit=11
//
// Nested calls in args. Asm backend used to reject these with
// `NestedCallInArg`; now it spills each arg to a 16-byte stack temp via
// a three-phase push/load/unwind so inner calls can run between phase-1
// pushes without corrupting the outer call's discipline.
//
// Before the fix, expressing this required hoisting every subexpression
// to a let. Cuts boilerplate ~3× in real model code.
extern fn aether_test_add_f32(a: f32, b: f32) -> f32;
extern fn aether_test_f32_to_i64(x: f32) -> i64;

fn main() -> i32 {
    // Nested f32 → i64 cast wrapping a nested f32 add.
    //   add(add(2.5, 3.0), add(1.5, 4.0)) = 5.5 + 5.5 = 11.0  → 11
    i64(aether_test_add_f32(
        aether_test_add_f32(2.5, 3.0),
        aether_test_add_f32(1.5, 4.0)))
}
