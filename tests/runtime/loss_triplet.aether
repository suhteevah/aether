// roadmap: P7.6
// expect: exit=0
// Triplet margin loss. Anchor/positive/negative are 4-d. With margin=1.0
// and the seed data below, ||a-p||^2 = 0.04 and ||a-n||^2 = 4.0, so the
// loss = max(0, 0.04 - 4.0 + 1.0) = 0 (inactive). Switch to a triplet
// where positive is far and negative is near to make it active.
use runtime;

fn main() -> i32 {
    let d: i32 = 4;
    let a:  i64 = aether_alloc_f32(d);
    let p:  i64 = aether_alloc_f32(d);
    let nn: i64 = aether_alloc_f32(d);
    let da: i64 = aether_alloc_f32(d);
    if a == 0 { return 1; }
    let margin: f32 = 1.0;

    aether_store_f32(a, 0, 1.0);
    aether_store_f32(a, 1, 2.0);
    aether_store_f32(a, 2, 3.0);
    aether_store_f32(a, 3, 4.0);

    aether_store_f32(p, 0, 2.0);
    aether_store_f32(p, 1, 3.0);
    aether_store_f32(p, 2, 4.0);
    aether_store_f32(p, 3, 5.0);

    aether_store_f32(nn, 0, 1.1);
    aether_store_f32(nn, 1, 2.1);
    aether_store_f32(nn, 2, 3.1);
    aether_store_f32(nn, 3, 4.1);

    aether_op_triplet_backward_f32(a, p, nn, da, d, margin);

    let eps: f32 = 0.001;
    let tol: f32 = 0.01;
    let mut i: i32 = 0;
    while i < d {
        let saved: f32 = aether_load_f32(a, i);
        aether_store_f32(a, i, saved + eps);
        let lp: f32 = aether_op_triplet_f32(a, p, nn, d, margin);
        aether_store_f32(a, i, saved - eps);
        let lm: f32 = aether_op_triplet_f32(a, p, nn, d, margin);
        aether_store_f32(a, i, saved);
        let num: f32 = (lp - lm) / (2.0 * eps);
        let ana: f32 = aether_load_f32(da, i);
        if aether_abs_f32(num - ana) > tol { return 2 + i; }
        i = i + 1;
    }
    0
}
