// roadmap: P17.14
// expect: exit=42
//
// FR-17.14-extra-deeper — Real GGUF reader walks Qwen2.5-7B's
// 339 tensors. This is matt-voice's actual base model, pulled
// from ollama's blob store (no extra download needed).
//
// What this witness PROVES end-to-end:
//   - Aether opens a real 4.7 GB GGUF file from disk.
//   - The v3 header parses (magic=GGUF, version=3, tensor_count=339).
//   - The metadata KV table walks cleanly (34 entries including the
//     BOOL value type whose 1-byte size is a common parser pitfall).
//   - The tensor info table walks cleanly: tensor 0 is
//     `token_embd.weight` (Qwen2.5's embedding matrix), dtype 12
//     (= Q4_K = matt-voice's quant format).
//   - aether_gguf_get_tensor_data_ptr returns a non-zero pointer
//     into the blob's data section — the same pointer can be passed
//     to aether_dequant_q4_k_m to actually read weights.
//
// SCOPE caveats (FR-17.14-extra-deeper-deeper):
//   - We don't yet run a forward pass through these weights.
//   - mmap'd I/O would beat the std::fs::read full-file load.
//   - Some tensors are non-Q4_K (output norm = F32, etc.); the
//     dequant kernel for each shape lives in its own FR.
use runtime;

extern fn aether_copy_cstr(dst: i64, cstr: i64, max: i32) -> i32;
extern fn aether_gguf_open(path: i64, n_path: i32) -> i64;
extern fn aether_gguf_close(h: i64) -> i32;
extern fn aether_gguf_version(h: i64) -> i32;
extern fn aether_gguf_n_tensors(h: i64) -> i32;
extern fn aether_gguf_get_tensor_name(h: i64, i: i32, out: i64, max: i32) -> i32;
extern fn aether_gguf_get_tensor_dtype(h: i64, i: i32) -> i32;
extern fn aether_gguf_get_tensor_shape(h: i64, i: i32, out_dims: i64, max_dims: i32) -> i32;
extern fn aether_gguf_get_tensor_data_ptr(h: i64, i: i32) -> i64;

fn main() -> i32 {
    let path: i64 = aether_alloc_bytes(256);
    let path_n: i32 = aether_copy_cstr(
        path,
        "C:/Users/Matt/.ollama/models/blobs/sha256-2bada8a7450677000f678be90653b85d364de7db25eb5ea54136ada5f3933730",
        200,
    );
    if path_n <= 0 { return 1; }

    let h: i64 = aether_gguf_open(path, path_n);
    if h < 0 { return 2; }

    // Version 3.
    if aether_gguf_version(h) != 3 { return 3; }

    // Qwen2.5-7B-Instruct has exactly 339 tensors.
    if aether_gguf_n_tensors(h) != 339 { return 4; }

    // Tensor 0: name should be "token_embd.weight" (17 bytes).
    let name_buf: i64 = aether_alloc_bytes(256);
    let n_name: i32 = aether_gguf_get_tensor_name(h, 0, name_buf, 256);
    if n_name != 17 { return 5; }
    // Verify a few key bytes of "token_embd.weight":
    if aether_byte_at(name_buf, 0) != 116 { return 6; }  // 't'
    if aether_byte_at(name_buf, 5) != 95  { return 7; }  // '_'
    if aether_byte_at(name_buf, 10) != 46 { return 8; }  // '.'
    if aether_byte_at(name_buf, 16) != 116 { return 9; } // 't' (last char of "weight")

    // Tensor 0's dtype should be Q4_K = 12.
    if aether_gguf_get_tensor_dtype(h, 0) != 12 { return 10; }

    // Tensor 0's shape should be 2D: [hidden_dim, vocab_size] or similar.
    let dims: i64 = aether_alloc_bytes(64);
    let n_dims: i32 = aether_gguf_get_tensor_shape(h, 0, dims, 8);
    if n_dims != 2 { return 11; }

    // Get the data pointer; must be non-zero.
    let dptr: i64 = aether_gguf_get_tensor_data_ptr(h, 0);
    if dptr == 0 { return 12; }

    aether_gguf_close(h);
    aether_free_bytes(path, 256);
    aether_free_bytes(name_buf, 256);
    aether_free_bytes(dims, 64);
    42
}
