// expect: exit=42
// roadmap: P12.3
// `async fn` parses; `.await` parses. Today both are pass-throughs — the
// lowering runs synchronously. Real executor + state-machine transform is
// future work. The witness proves the parser surface is wired and the asm
// backend produces a runnable .exe.
async fn add_two(a: i64, b: i64) -> i64 {
    a + b
}

async fn double(x: i64) -> i64 {
    x + x
}

fn main() -> i32 {
    let s: i64 = add_two(20, 1).await;
    let d: i64 = double(s).await;     // 42
    d as i32
}
