// roadmap: P19.1
// expect: exit=42
//
// FR-19.1-extra — TLS 1.3 (RFC 8446) server-side handshake.
//
// Profile (in scope):
//   - cipher suite TLS_CHACHA20_POLY1305_SHA256
//   - key_share group X25519
//   - signature alg ed25519
//   - self-signed Ed25519 X.509 leaf cert
//   - server-side only (no PSK / 0-RTT / resumption / ALPN)
//
// The witness drives `aether_tls13_self_loopback_smoke()` in
// `runtime/src/tls13.rs`. That fn runs the full handshake in-process:
//   1) Build ClientHello with x25519 key_share
//   2) Server parses CH, derives DHE shared secret, emits
//      ServerHello (cleartext) + encrypted {EE, Cert, CV, Finished}
//   3) Client decrypts the server flight, verifies the Ed25519
//      CertificateVerify signature against the in-cert SPKI public
//      key, recomputes the server Finished HMAC, and sends its own
//      encrypted Finished
//   4) Server accepts client Finished and transitions to Connected
//   5) Both sides exchange one TLSCiphertext application_data record
//      and verify byte-for-byte equality
//
// All crypto runs through aether_rt's from-scratch impls:
//   SHA-256, HMAC-SHA256, HKDF-Extract/Expand/Expand-Label,
//   X25519, Ed25519, ChaCha20-Poly1305.
// Zero external crypto deps.
use runtime;

extern fn aether_tls13_self_loopback_smoke() -> i32;

fn main() -> i32 {
    aether_tls13_self_loopback_smoke()
}
