// roadmap: P6.6
// expect: exit=42
//
// A CAPTURING closure passed as a VALUE to another fn — the case the
// closure-lifting pass punted on. `inc` captures `acc` by value; it is
// materialized as a heap closure object `[fn_ptr | acc]` and `apply` invokes
// it through its `Closure`-typed parameter (env pointer prepended), so the
// captured `acc` survives the hand-off.
fn apply(f: Closure, x: i64) -> i64 {
    f(x)
}

fn main() -> i32 {
    let acc: i64 = 37;
    let inc = |x: i64| acc + x;     // captures acc by value
    let r = apply(inc, 5);          // 37 + 5 = 42 (acc survives the call)
    r as i32
}
