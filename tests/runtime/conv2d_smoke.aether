// roadmap: P17.3
// expect: exit=42
//
// FR-17.3 witness — 2D convolution (CPU reference path).
//
// Setup:
//   input  shape (1, 1, 4, 4) = [1..16] row-major
//   kernel shape (1, 1, 3, 3) = all 1.0
//   output shape (1, 1, 2, 2) — the 4 windows summed in row-major:
//     out[0,0,0,0] = 1+2+3 + 5+6+7 + 9+10+11   = 54
//     out[0,0,0,1] = 2+3+4 + 6+7+8 + 10+11+12  = 63
//     out[0,0,1,0] = 5+6+7 + 9+10+11 + 13+14+15 = 90
//     out[0,0,1,1] = 6+7+8 + 10+11+12 + 14+15+16 = 99
//
// Exit 42 iff all four cells match exactly. Exit codes 1..6 localise
// the failure (alloc / per-cell mismatch).
use runtime;

extern fn aether_op_conv2d_f32(
    input: i64, kernel: i64, output: i64,
    n: i32, c_in: i32, h: i32, w: i32,
    c_out: i32, kh: i32, kw: i32,
) -> i32;

fn main() -> i32 {
    let input:  i64 = aether_alloc_f32(16);
    let kernel: i64 = aether_alloc_f32(9);
    let output: i64 = aether_alloc_f32(4);
    if input  == 0 { return 1; }
    if kernel == 0 { return 1; }
    if output == 0 { return 1; }

    // Fill input with 1..16 (row-major NCHW).
    let mut i: i32 = 0;
    while i < 16 {
        let v: f32 = f32(i + 1);
        aether_store_f32(input, i, v);
        i = i + 1;
    }
    // Fill kernel with 1.0.
    let mut j: i32 = 0;
    while j < 9 {
        aether_store_f32(kernel, j, 1.0);
        j = j + 1;
    }

    let rc: i32 = aether_op_conv2d_f32(input, kernel, output,
                                       1, 1, 4, 4,
                                       1, 3, 3);
    if rc != 0 { return 2; }

    let o00: f32 = aether_load_f32(output, 0);
    let o01: f32 = aether_load_f32(output, 1);
    let o10: f32 = aether_load_f32(output, 2);
    let o11: f32 = aether_load_f32(output, 3);

    aether_free_f32(input,  16);
    aether_free_f32(kernel, 9);
    aether_free_f32(output, 4);

    if o00 != 54.0 { return 3; }
    if o01 != 63.0 { return 4; }
    if o10 != 90.0 { return 5; }
    if o11 != 99.0 { return 6; }
    42
}
