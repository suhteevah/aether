// roadmap: P7.6
// expect: exit=0
// Huber(delta=1.0). Diffs chosen so all are well clear of |d|=delta:
// element 0: |d|=0.5 (quadratic regime); elements 1..3: |d|>=1.5 (linear regime).
use runtime;

fn main() -> i32 {
    let n: i32 = 4;
    let pred:   i64 = aether_alloc_f32(n);
    let target: i64 = aether_alloc_f32(n);
    let dpred:  i64 = aether_alloc_f32(n);
    if pred == 0 { return 1; }
    let delta: f32 = 1.0;

    aether_store_f32(pred, 0, 1.5);
    aether_store_f32(pred, 1, 4.0);
    aether_store_f32(pred, 2, 0.0);
    aether_store_f32(pred, 3, 5.0);

    aether_store_f32(target, 0, 1.0);
    aether_store_f32(target, 1, 0.0);
    aether_store_f32(target, 2, 2.0);
    aether_store_f32(target, 3, 1.5);

    aether_op_huber_backward_f32(pred, target, dpred, n, delta);

    let eps: f32 = 0.001;
    let tol: f32 = 0.005;
    let mut i: i32 = 0;
    while i < n {
        let saved: f32 = aether_load_f32(pred, i);
        aether_store_f32(pred, i, saved + eps);
        let lp: f32 = aether_op_huber_f32(pred, target, n, delta);
        aether_store_f32(pred, i, saved - eps);
        let lm: f32 = aether_op_huber_f32(pred, target, n, delta);
        aether_store_f32(pred, i, saved);
        let num: f32 = (lp - lm) / (2.0 * eps);
        let ana: f32 = aether_load_f32(dpred, i);
        if aether_abs_f32(num - ana) > tol { return 2 + i; }
        i = i + 1;
    }
    0
}
