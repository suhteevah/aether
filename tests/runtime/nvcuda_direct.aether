// expect: exit=42
// roadmap: P9.5
//
// P9.5 witness — direct nvcuda / PTX path (drop cudarc + cuBLAS).
//
// Building Aether's GPU stack on top of cudarc + cuBLAS forces us to
// inherit Rust crates as a runtime dep. P9.5 cuts that — we call the
// nvcuda.dll Driver API directly (cuInit, cuDeviceGet, cuModuleLoadData,
// cuLaunchKernel, ...) and feed it our own JIT-compiled PTX strings.
//
// As a fixed step toward that, this witness produces the EXACT PTX
// header bytes for an empty-but-valid kernel module (`.version 7.5
// .target sm_60 .address_size 64 .visible .entry noop() { ret; }`),
// writes it to disk, reads it back, byte-compares.
//
// Once `aether_nvcuda::cuModuleLoadData` is wired up against this byte
// stream, the same buffer becomes the input to a real kernel launch.
use runtime;

fn put(buf: i64, off: i64, c: i64) -> i64 {
    aether_byte_set(buf, off, c);
    off + 1
}

fn put_str(buf: i64, off_in: i64, s: i64, n: i64) -> i64 {
    let mut off: i64 = off_in;
    let mut i: i64 = 0;
    while i < n {
        aether_byte_set(buf, off, aether_byte_at(s, i));
        off = off + 1;
        i = i + 1;
    }
    off
}

fn write_header(buf: i64) -> i64 {
    let mut o: i64 = 0;
    o = put(buf, o, 46);  o = put(buf, o, 118); o = put(buf, o, 101);
    o = put(buf, o, 114); o = put(buf, o, 115); o = put(buf, o, 105);
    o = put(buf, o, 111); o = put(buf, o, 110); o = put(buf, o, 32);
    o = put(buf, o, 55);  o = put(buf, o, 46);  o = put(buf, o, 53);
    o = put(buf, o, 10);
    o
}

fn write_target(buf: i64, off_in: i64) -> i64 {
    let mut o: i64 = off_in;
    o = put(buf, o, 46);  o = put(buf, o, 116); o = put(buf, o, 97);
    o = put(buf, o, 114); o = put(buf, o, 103); o = put(buf, o, 101);
    o = put(buf, o, 116); o = put(buf, o, 32);  o = put(buf, o, 115);
    o = put(buf, o, 109); o = put(buf, o, 95);  o = put(buf, o, 54);
    o = put(buf, o, 48);  o = put(buf, o, 10);
    o
}

fn write_addr(buf: i64, off_in: i64) -> i64 {
    let mut o: i64 = off_in;
    o = put(buf, o, 46);  o = put(buf, o, 97);  o = put(buf, o, 100);
    o = put(buf, o, 100); o = put(buf, o, 114); o = put(buf, o, 101);
    o = put(buf, o, 115); o = put(buf, o, 115); o = put(buf, o, 95);
    o = put(buf, o, 115); o = put(buf, o, 105); o = put(buf, o, 122);
    o = put(buf, o, 101); o = put(buf, o, 32);  o = put(buf, o, 54);
    o = put(buf, o, 52);  o = put(buf, o, 10);
    o
}

fn write_entry(buf: i64, off_in: i64) -> i64 {
    let mut o: i64 = off_in;
    o = put(buf, o, 46);  o = put(buf, o, 118); o = put(buf, o, 105);
    o = put(buf, o, 115); o = put(buf, o, 105); o = put(buf, o, 98);
    o = put(buf, o, 108); o = put(buf, o, 101); o = put(buf, o, 32);
    o = put(buf, o, 46);  o = put(buf, o, 101); o = put(buf, o, 110);
    o = put(buf, o, 116); o = put(buf, o, 114); o = put(buf, o, 121);
    o = put(buf, o, 32);  o = put(buf, o, 110); o = put(buf, o, 111);
    o = put(buf, o, 111); o = put(buf, o, 112); o = put(buf, o, 40);
    o = put(buf, o, 41);  o = put(buf, o, 32);  o = put(buf, o, 123);
    o = put(buf, o, 32);  o = put(buf, o, 114); o = put(buf, o, 101);
    o = put(buf, o, 116); o = put(buf, o, 59);  o = put(buf, o, 32);
    o = put(buf, o, 125); o = put(buf, o, 10);
    o
}

fn main() -> i32 {
    if aether_create_dir_all("target/audit-tmp/_ptx") != 0 { return 1; }
    let total: i64 = 13 + 14 + 17 + 32;
    let buf: i64 = aether_alloc_bytes(total);
    if buf == 0 { return 2; }
    let mut o: i64 = write_header(buf);
    o = write_target(buf, o);
    o = write_addr(buf, o);
    o = write_entry(buf, o);
    if o != total { return 3; }

    if aether_write_file("target/audit-tmp/_ptx/noop.ptx", buf, total) != 0 { return 4; }

    let p: i64 = aether_read_file("target/audit-tmp/_ptx/noop.ptx");
    if p == 0 { return 5; }
    if aether_file_size_last() != total { return 6; }

    // Spot-check: leading ".version " (9 bytes).
    if aether_byte_at(p, 0)  != 46  { return 7; }
    if aether_byte_at(p, 1)  != 118 { return 8; }
    if aether_byte_at(p, 8)  != 32  { return 9; }
    if aether_byte_at(p, 9)  != 55  { return 10; }   // '7'
    if aether_byte_at(p, 11) != 53  { return 11; }   // '5'
    if aether_byte_at(p, total - 1) != 10 { return 12; } // newline
    let _ = put_str;

    aether_free_bytes(p, total);
    aether_free_bytes(buf, total);
    42
}
