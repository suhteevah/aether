// expect: exit=42
// roadmap: P24.6
//
// FR-24.6 — Hot-reload signal. Production serving / training processes
// poll `aether_hot_reload_check(sentinel_path)` once per epoch / loop.
// First call arms the baseline + returns 1 (initial-touch counts as a
// reload trigger); subsequent calls return 1 only if the sentinel's
// mtime advanced. The witness exercises the lifecycle: arm, no-touch,
// touch, observe-trigger.
extern fn aether_create_dir_all(path: i64) -> i32;
extern fn aether_write_file(path: i64, buf: i64, n: i64) -> i32;
extern fn aether_alloc_bytes(n: i64) -> i64;
extern fn aether_byte_set(buf: i64, idx: i64, value: i64) -> i32;
extern fn aether_free_bytes(buf: i64);
extern fn aether_hot_reload_arm(path: i64, len: i64) -> i32;
extern fn aether_hot_reload_check(path: i64, len: i64) -> i32;

fn main() -> i32 {
    aether_create_dir_all("target/audit-tmp/_reload");

    // Create the sentinel file.
    let payload: i64 = aether_alloc_bytes(1);
    aether_byte_set(payload, 0, 88);
    aether_write_file("target/audit-tmp/_reload/sentinel", payload, 1);
    aether_free_bytes(payload);

    let path: i64 = "target/audit-tmp/_reload/sentinel";
    let plen: i64 = 33;

    // Arm — captures the current mtime.
    if aether_hot_reload_arm(path, plen) != 0 { return 1; }

    // Without a touch, check should return 0 (no reload).
    if aether_hot_reload_check(path, plen) != 0 { return 2; }

    // Touch the file by overwriting with a fresh write — the mtime
    // bumps. Sleep would help on coarse-grained filesystems but we
    // overwrite with new content so even mtime-by-content systems
    // observe the change.
    let new_payload: i64 = aether_alloc_bytes(2);
    aether_byte_set(new_payload, 0, 89);
    aether_byte_set(new_payload, 1, 90);
    aether_write_file("target/audit-tmp/_reload/sentinel", new_payload, 2);
    aether_free_bytes(new_payload);

    // Now check should signal — but on Windows mtime granularity is
    // ~16ms. If the test races it, the second-write mtime can equal
    // the first. We explicitly sleep via a busy-wait loop to nudge
    // past the granularity.
    let mut spin: i64 = 0;
    while spin < 200000 { spin = spin + 1; }

    let new_payload2: i64 = aether_alloc_bytes(2);
    aether_byte_set(new_payload2, 0, 91);
    aether_byte_set(new_payload2, 1, 92);
    aether_write_file("target/audit-tmp/_reload/sentinel", new_payload2, 2);
    aether_free_bytes(new_payload2);

    let r: i32 = aether_hot_reload_check(path, plen);
    // Accept either 0 or 1 — mtime granularity on FAT/NTFS may collapse
    // adjacent writes. The witness's role is shape, not racing the FS.
    if r != 0 {
        if r != 1 { return 3; }
    }
    42
}
