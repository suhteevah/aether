// roadmap: P16.19
// expect: exit=42
//
// `&[u8]` / `&str` slices — a (ptr, len) fat pointer over a String's UTF-8
// buffer. Exercises width-correct byte loads (movzbl, NOT the i64-only movq):
//   * full-slice construction over a String's backing buffer
//   * `.len()`
//   * byte indexing `s[i]` (1-byte load, zero-extended)
//   * sub-slicing `&s[a..b]`
//
//   string = "ABC" = [65, 66, 67]
//   bytes  = &str   → len 3, bytes[0]=65, bytes[2]=67
//   sub    = &bytes[1..3] → len 2, sub[0]=66
//   result = bytes[0] + bytes[2] - sub[0] - 24 = 65 + 67 - 66 - 24 = 42
use runtime;

fn main() -> i32 {
    let s: i64 = aether_string_new();
    aether_string_push_byte(s, 65);   // 'A'
    aether_string_push_byte(s, 66);   // 'B'
    aether_string_push_byte(s, 67);   // 'C'

    let bytes: &[u8] = slice_from_raw(aether_string_as_ptr(s), aether_string_len(s));
    if bytes.len() != 3 { return 1; }
    if bytes[0] != 65 { return 2; }
    if bytes[2] != 67 { return 3; }

    let sub: &[u8] = &bytes[1..3];
    if sub.len() != 2 { return 4; }
    if sub[0] != 66 { return 5; }

    let result: i64 = bytes[0] + bytes[2] - sub[0] - 24;   // 65 + 67 - 66 - 24 = 42
    aether_string_free(s);
    return result as i32;
}
