// expect: exit=0
// requires: cuda
//
// The cleanest end-to-end GPU training program Aether can express today.
// Comparison with the original `cuda_train_tiny.aether` (~80 lines):
//   * `use runtime;` replaces 25 lines of `extern fn` decls.
//   * `Tensor<…> with auto-alloc/free` replaces 9 alloc + 9 free calls.
//   * `const BSZ`, `const KK`, `const NN` parameterise every shape;
//     change one number, the whole graph reshapes.
//   * Method-call dispatch replaces 5 `aether_op_*_cuda(x, w, y, M, K, N)`
//     calls with `x.matmul(&w, &mut y)`-style — M/K/N pulled from the
//     Tensor's compile-time shape.
//
// Same model, same hyperparameters, same seed, bit-identical loss curve
// to every prior `train_tiny.aether` variant.
use runtime;

const BSZ: i32 = 8;
const KK:  i32 = 16;
const NN:  i32 = 4;
const KN:  i32 = 64;     // KK * NN — material count for adamw arrays

fn main() -> i32 {
    aether_dev_init();

    let h_x: i64 = aether_alloc_f32(128);
    let h_w: i64 = aether_alloc_f32(64);
    let h_lab: i64 = aether_alloc_i32(8);
    aether_init_normal_f32(h_x, 128, 1.0, 1);
    aether_init_normal_f32(h_w, 64, 0.1, 7);
    aether_fill_labels_i32(h_lab, 8, 4, 13);

    let x:      Tensor<f32, [BSZ, KK]>;
    let w:      Tensor<f32, [KK, NN]>;
    let y:      Tensor<f32, [BSZ, NN]>;
    let probs:  Tensor<f32, [BSZ, NN]>;
    let dy:     Tensor<f32, [BSZ, NN]>;
    let dw:     Tensor<f32, [KK, NN]>;
    let mom1:   Tensor<f32, [KN]>;
    let mom2:   Tensor<f32, [KN]>;
    let labels: Tensor<i32, [BSZ]>;

    aether_dev_h2d_f32(h_x, x, 128);
    aether_dev_h2d_f32(h_w, w, 64);
    aether_dev_h2d_i32(h_lab, labels, 8);

    let mut initial: f32 = 0.0;
    let mut final_loss: f32 = 0.0;
    let mut s: i64 = 1;
    while s <= 50 {
        x.matmul(&w, &mut y);
        let loss: f32 = y.cross_entropy(&labels, &mut probs);
        if s == 1 { initial = loss; }
        final_loss = loss;
        probs.cross_entropy_backward(&labels, &mut dy);
        x.matmul_backward_rhs(&dy, &mut dw);
        w.adamw_step(&dw, &mut mom1, &mut mom2, 0.05, 0.9, 0.999, 0.00000001, 0.0, s);
        s = s + 1;
    }
    aether_dev_sync();

    aether_free_f32(h_x, 128);
    aether_free_f32(h_w, 64);
    aether_free_i32(h_lab, 8);

    if final_loss < initial { 0 } else { 1 }
}
