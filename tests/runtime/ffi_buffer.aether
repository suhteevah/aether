// expect: exit=0
// Address-of-local + FFI: take the address of a stack int, hand it to the
// runtime as a fake "tape pointer", verify push reads it without crashing.
// (The Phase-0 runtime stores pointers but doesn't deref them, so this is a
// linkage smoke; real buffer-deref FFI lands in Phase 1.)
extern fn aether_autodiff_init(tape: i64) -> i32;
extern fn aether_autodiff_push(tape: i64, value: i64) -> i32;
extern fn aether_rt_self_check() -> i32;

fn main() -> i32 {
    let local = 42;
    aether_autodiff_init(0);
    for i in 0..5 {
        aether_autodiff_push(0, &local);
    }
    let n = aether_rt_self_check();
    n - 5
}
