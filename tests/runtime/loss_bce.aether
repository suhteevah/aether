// roadmap: P7.6
// expect: exit=0
// BCE on probabilities. Pred values stay safely inside (0,1).
use runtime;

fn main() -> i32 {
    let n: i32 = 4;
    let pred:   i64 = aether_alloc_f32(n);
    let target: i64 = aether_alloc_f32(n);
    let dpred:  i64 = aether_alloc_f32(n);
    if pred == 0 { return 1; }

    aether_store_f32(pred, 0, 0.3);
    aether_store_f32(pred, 1, 0.7);
    aether_store_f32(pred, 2, 0.5);
    aether_store_f32(pred, 3, 0.9);

    aether_store_f32(target, 0, 0.0);
    aether_store_f32(target, 1, 1.0);
    aether_store_f32(target, 2, 0.5);
    aether_store_f32(target, 3, 1.0);

    aether_op_bce_backward_f32(pred, target, dpred, n);

    let eps: f32 = 0.001;
    let tol: f32 = 0.005;
    let mut i: i32 = 0;
    while i < n {
        let saved: f32 = aether_load_f32(pred, i);
        aether_store_f32(pred, i, saved + eps);
        let lp: f32 = aether_op_bce_f32(pred, target, n);
        aether_store_f32(pred, i, saved - eps);
        let lm: f32 = aether_op_bce_f32(pred, target, n);
        aether_store_f32(pred, i, saved);
        let num: f32 = (lp - lm) / (2.0 * eps);
        let ana: f32 = aether_load_f32(dpred, i);
        if aether_abs_f32(num - ana) > tol { return 2 + i; }
        i = i + 1;
    }
    0
}
