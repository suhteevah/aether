// expect: exit=42
// `else if` chains — desugars to nested if/else blocks.
fn classify(x: i64) -> i64 {
    if x < 0 {
        1
    } else if x == 0 {
        2
    } else if x < 10 {
        3
    } else if x < 100 {
        42
    } else {
        99
    }
}
fn main() -> i32 {
    classify(50) as i32
}
