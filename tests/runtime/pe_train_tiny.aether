// expect: exit=0
// build-mode: pe-bin
//
// End-to-end model training driven from this .aether source through the
// SELF-HOSTED PE32+ writer (#24, full cut). The .exe is produced via:
//   aetherc → x86-64 asm (ours) → COFF (ours) → PE32+ writer (ours)
// with kernel32.dll + aether_rt.dll resolved by our own multi-DLL IAT.
// **Zero external linker.** (Compare with `train_tiny.aether`, which
// goes through `--emit=aether-bin` and the system linker.)
//
// Same model as train_tiny: single linear layer, B=8, K=16, N=4. Exits 0
// iff loss decreased over 50 steps of forward + cross-entropy + backward
// + AdamW. Uses the slim `runtime_pe` cdylib's f32-only / no-libm-trampoline
// op surface — `aether_init_normal_f32` is a uniform-init substitute (all
// libm f64 entries AV in the SAVE_XMM prologue when the DLL loads under
// `--emit=pe-bin`; see `runtime_pe/src/lib.rs` for the full diagnosis).

extern fn aether_alloc_f32(n: i32) -> i64;
extern fn aether_alloc_i32(n: i32) -> i64;
extern fn aether_free_f32(p: i64, n: i32) -> i32;
extern fn aether_free_i32(p: i64, n: i32) -> i32;
extern fn aether_init_normal_f32(p: i64, n: i32, scale: f32, seed: i64) -> i32;
extern fn aether_fill_labels_i32(p: i64, n: i32, classes: i32, seed: i64) -> i32;
extern fn aether_op_matmul_f32(a: i64, b: i64, out: i64, m: i32, k: i32, n: i32) -> i32;
extern fn aether_op_matmul_backward_rhs_f32(a: i64, dy: i64, db: i64, m: i32, k: i32, n: i32) -> i32;
extern fn aether_op_cross_entropy_f32(logits: i64, labels: i64, probs_out: i64, b: i32, v: i32) -> f32;
extern fn aether_op_cross_entropy_backward_f32(probs: i64, labels: i64, dlogits: i64, b: i32, v: i32) -> i32;
extern fn aether_op_adamw_step_f32(
    param: i64, grad: i64, m: i64, v: i64,
    lr: f32, beta1: f32, beta2: f32, eps: f32, wd: f32,
    step: i64, n: i32
) -> i32;

fn main() -> i32 {
    let bsz: i32 = 8;
    let kk: i32 = 16;
    let nn: i32 = 4;
    let bk: i32 = bsz * kk;
    let kn: i32 = kk * nn;
    let bn: i32 = bsz * nn;

    let x: i64      = aether_alloc_f32(bk);
    let w: i64      = aether_alloc_f32(kn);
    let y: i64      = aether_alloc_f32(bn);
    let probs: i64  = aether_alloc_f32(bn);
    let dy: i64     = aether_alloc_f32(bn);
    let dw: i64     = aether_alloc_f32(kn);
    let mom1: i64   = aether_alloc_f32(kn);
    let mom2: i64   = aether_alloc_f32(kn);
    let labels: i64 = aether_alloc_i32(bsz);

    aether_init_normal_f32(x, bk, 1.0, 1);
    aether_init_normal_f32(w, kn, 0.1, 7);
    aether_fill_labels_i32(labels, bsz, nn, 13);

    let mut initial: f32 = 0.0;
    let mut final_loss: f32 = 0.0;
    let mut s: i64 = 1;
    while s <= 50 {
        aether_op_matmul_f32(x, w, y, bsz, kk, nn);
        let loss: f32 = aether_op_cross_entropy_f32(y, labels, probs, bsz, nn);
        if s == 1 { initial = loss; }
        final_loss = loss;
        aether_op_cross_entropy_backward_f32(probs, labels, dy, bsz, nn);
        aether_op_matmul_backward_rhs_f32(x, dy, dw, bsz, kk, nn);
        aether_op_adamw_step_f32(w, dw, mom1, mom2, 0.05, 0.9, 0.999, 0.00000001, 0.0, s, kn);
        s = s + 1;
    }

    aether_free_f32(x, bk);
    aether_free_f32(w, kn);
    aether_free_f32(y, bn);
    aether_free_f32(probs, bn);
    aether_free_f32(dy, bn);
    aether_free_f32(dw, kn);
    aether_free_f32(mom1, kn);
    aether_free_f32(mom2, kn);
    aether_free_i32(labels, bsz);

    if final_loss < initial { 0 } else { 1 }
}
