.section .rdata,"dr"
.LC0:
    .asciz "Hello from Aether - close to the metal"

.section .text
.globl main

main:
    pushq %rbp
    movq %rsp, %rbp
    subq $32, %rsp
    leaq .LC0(%rip), %rcx
    callq puts
    movq $0, %rax
    addq $32, %rsp
    popq %rbp
    ret

